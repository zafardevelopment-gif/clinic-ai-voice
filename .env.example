# ─────────────────────────────────────────────────────────────────────────────
# ClinicAI — Environment Variables
# Copy this file to .env.local and fill in real values.
# Do NOT commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────────────────────
# Public URL where this Next.js app is reachable (used in Twilio webhook URLs
# for signature validation). For local Twilio testing use an ngrok tunnel URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret the (future) voice WebSocket worker uses to call /api/tools/*
# Generate with: openssl rand -hex 32
WORKER_SECRET=replace-with-random-32-char-hex

# ── Telephony provider selection ─────────────────────────────────────────────
# 'twilio' (default, dev/testing) or 'exotel' (India production, requires
# Voicebot Streaming plan for real-time AI calls).
TELEPHONY_PROVIDER=twilio

# ── Twilio (required when TELEPHONY_PROVIDER=twilio) ─────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# Outbound caller ID used for reminder calls when a clinic has no .phone set.
# Must be a Twilio-verified or purchased number in E.164 format.
TWILIO_OUTBOUND_FROM=+1234567890

# ── Exotel (required when TELEPHONY_PROVIDER=exotel) ─────────────────────────
# Populate from your Exotel dashboard once KYC is approved.
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=api.exotel.com

# ── OpenRouter (LLM gateway — Claude Haiku / GPT-4o-mini) ────────────────────
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheap+fast model good for intent classification & short replies.
OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# ── Sarvam AI (Hindi/Indic STT + TTS) — optional, needed for voice worker ───
SARVAM_API_KEY=your-sarvam-api-key
SARVAM_API_URL=https://api.sarvam.ai

# ── ElevenLabs (premium English TTS) — optional ─────────────────────────────
ELEVENLABS_API_KEY=

# ── Voice WebSocket worker (Phase 2) ────────────────────────────────────────
# Public wss:// URL where the standalone worker is deployed (Fly.io/Railway).
# Empty in early phases — incoming-call route falls back to non-streaming TwiML.
VOICE_WORKER_URL=

# ── ClinicPing Reminder Scheduler ────────────────────────────────────────────
# Secret protecting /api/cron/reminders. Vercel Cron sends this as a Bearer
# token in the Authorization header. Generate with: openssl rand -hex 32
# If unset, the scheduler falls back to WORKER_SECRET.
CRON_SECRET=replace-with-random-32-char-hex

# ── Custom Domains (per-clinic public website on their own domain) ──────────
# Fully automated via the Vercel Domains API — see CLINIC_OS_MODULES.md.
# VERCEL_API_TOKEN: Account Settings → Tokens → Create Token
# VERCEL_PROJECT_ID: Project → Settings → General → "Project ID" (prj_...)
# VERCEL_TEAM_ID: only if this project is under a Team — Team Settings →
#   General → "Team ID" (team_...). Leave blank for a personal-account project.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=


# Razorpay — get keys at https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_xxx) for development, live keys (rzp_live_xxx) for production
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET_HERE
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID_HERE
# Optional: set this in Razorpay dashboard > Webhooks to verify webhook authenticity
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
