# Voice worker environment. Copy to .env for local dev; set the same vars in
# Render (or your host) for production.

PORT=8080

# Supabase (same project as the Next.js app) — service role for DB writes.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sarvam (STT + TTS)
SARVAM_API_KEY=sk_xxx
SARVAM_API_URL=https://api.sarvam.ai

# OpenRouter (LLM, used by the Sarvam pipeline)
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-haiku-4-5

# ── Voice engine ─────────────────────────────────────────────────────────────
# 'openai'  → OpenAI Realtime API (fast, natural, barge-in). Needs OPENAI_API_KEY.
# 'sarvam'  → Sarvam STT/TTS pipeline (best Indian-language voice, slower). Default.
VOICE_ENGINE=sarvam

# OpenAI Realtime (only needed when VOICE_ENGINE=openai). This is a DIRECT
# OpenAI platform key (sk-proj-...), NOT the OpenRouter key.
OPENAI_API_KEY=sk-proj-xxx
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=shimmer
